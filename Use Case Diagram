%% UML Use Case Diagram for Device Repair System
%% Actors: Customer, Technician, Admin, Delivery Staff, Payment System, Notification System
%% Use Cases: 9+

%% Define actors
actor Customer
actor Technician
actor Admin
actor "Delivery Staff"
actor "Payment System"
actor "Notification System"

%% Define use cases
usecase "Register Device" as UC1
usecase "Record Device Intake" as UC2
usecase "Add Accessories" as UC3
usecase "Update Repair Status" as UC4
usecase "Track Repair Status" as UC5
usecase "Choose Service Option" as UC6
usecase "Calculate Profit" as UC7
usecase "View Reports" as UC8

%% Relationships
UC5 <<include>> UC4  %% Tracking repair includes updating status

%% Actor associations
Customer --> UC1
Customer --> UC5
Customer --> UC6

Technician --> UC2
Technician --> UC3
Technician --> UC4

Admin --> UC4
Admin --> UC7
Admin --> UC8

"Delivery Staff" --> UC2
"Delivery Staff" --> UC5

"Payment System" --> UC6
"Notification System" --> UC4
"Notification System" --> UC5
